{
    "version": "2.0.0",
    "tasks": [
        // backend build and run tasks (use the inbult run button on vscode)
        // requires cmake (brew install cmake)
        {
            "label": "CMake Build",
            "type": "shell",
            "command": "cmake --build ${workspaceFolder}/backend/build",
            "group": {
                "kind": "build",
                "isDefault": true   // have to set this other wise default c/cpp compiler trys to compile source without linking other source files
            },
            "problemMatcher": ["$gcc"]

        },
        {
            "label": "CMake Run Binary",
            "type": "shell",
            "command": "${workspaceFolder}/backend/build/bin/dnp3",  // TODO: Change name to dnp3Backend. Have to change in CMake as well
            "dependsOn": "CMake Build",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": "$gcc"
        },

        // frontend compile and run commmands
        // requires jdk (i think... pretty sure though)
        {
            "label": "Java Compile",
            "type": "shell",
            "command": "javac -d bin src/**/*.java",
            "options": {
                "cwd": "${workspaceFolder}/frontend"    // launch shell in frontend folder
            },
            "group": "build",
            "problemMatcher": ["$msCompile"]
        },
        {
            "label": "Run Java Frontend",
            "type": "shell",
            "command": "java -cp bin Main",
            "group": "test",
            "options": {
                "cwd": "${workspaceFolder}/frontend"
            },
            "dependsOn": "Java Compile",
            "problemMatcher": []
        },

        // Clean Commands
        {
            "label": "Clean All",
            "type": "shell",
            "command": "rm -rf ${workspaceFolder}/frontend/bin && rm -rf ${workspaceFolder}/backend/bin",      // clean both backend and frontend folders
            "group": "none",
            "problemMatcher": []
        },
        {
            "label": "Clean Frontend",
            "type": "shell",
            "command": "rm -rf ${workspaceFolder}/frontend/bin",
            "group": "none",
            "problemMatcher": []
        },
        {
            "label": "Clean Backend",
            "type": "shell",
            "command": "rm -rf ${workspaceFolder}/backend/bin",
            "group": "none",
            "problemMatcher": []
        },
        
    ]
}